{
  "name": "@pragmatiks/lint",
  "version": "0.1.0",
  "description": "Pragmatiks engineering principles eslint config and bundled semgrep rules.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./eslint-config": {
      "types": "./dist/eslint-config/index.d.ts",
      "import": "./dist/eslint-config/index.js"
    }
  },
  "files": [
    "dist",
    "src/semgrep-rules",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "format": "prettier --write .",
    "check": "eslint . && tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "knip": "^6.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "knip": "^6.12.1",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "semgrep",
    "lint",
    "pragmatiks"
  ],
  "license": "MIT",
  "author": "Pragmatiks",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pragmatiks/pragma-lint.git",
    "directory": "js"
  }
}
